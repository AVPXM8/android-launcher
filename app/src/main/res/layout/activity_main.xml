<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.tools.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".view.MainActivity">

    <!-- Primary Workspace Layer (Desktop Workspace & Dock Container) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/workspaceContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60000000"> <!-- Glass translucent overlay over wallpaper -->

        <!-- Dynamic Drag Remove zone at the top (invisible by default, shown during drag) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/removeZone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#CCFF4444"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Drop here to Remove"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </androidx.cardview.widget.CardView>

        <!-- Subtle Top Clock Widget Placeholder for Launcher Feel -->
        <LinearLayout
            android:id="@+id/clockWidget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextClock
                android:id="@+id/clockText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-thin"
                android:format12Hour="hh:mm"
                android:format24Hour="HH:mm"
                android:textColor="#FFFFFF"
                android:textSize="54sp" />

            <TextClock
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:format12Hour="EEEE, d MMMM"
                android:format24Hour="EEEE, d MMMM"
                android:textColor="#E0E0E0"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Cellular Grid Workspace -->
        <com.vivex.launcher.homescreen.CellLayout
            android:id="@+id/workspaceGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@+id/dockDivider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/clockWidget" />

        <!-- Dock Divider Line -->
        <View
            android:id="@+id/dockDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="16dp"
            android:background="#33FFFFFF"
            app:layout_constraintBottom_toTopOf="@+id/dockCard"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Persistent Bottom Dock Section -->
        <androidx.cardview.widget.CardView
            android:id="@+id/dockCard"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="48dp"
            app:cardBackgroundColor="#25FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.vivex.launcher.homescreen.CellLayout
                android:id="@+id/dockGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="8dp" />
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Full-Screen App Drawer Fragment Container -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/drawerContainer"
        android:name="com.vivex.launcher.drawer.AppDrawerFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Center Progress Loader -->
    <ProgressBar
        android:id="@+id/loadingProgressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#BB86FC"
        android:visibility="gone"
        tools:visibility="visible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
